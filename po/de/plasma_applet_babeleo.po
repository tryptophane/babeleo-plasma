msgid "Click to query clipboard content"
msgstr "Klicken, um den Inhalt der Zwischenablage abzufragen"

#: applet/package/contents/ui/main.qml
msgid "Double-click to query clipboard content"
msgstr "Doppelklicken, um den Inhalt der Zwischenablage abzufragen"
