msgid "Click Behavior"
msgstr "Klickverhalten"

#: applet/package/contents/ui/configShortcuts.qml
msgid "Single click: search with clipboard content"
msgstr "Einfacher Klick: Inhalt der Zwischenablage suchen"

#: applet/package/contents/ui/configShortcuts.qml
msgid "Double click: search with clipboard content"
msgstr "Doppelklick: Inhalt der Zwischenablage suchen"

