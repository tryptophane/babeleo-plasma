#: applet/babeleo.cpp
msgid "Translate clipboard content"
msgstr "Traduci contenuto degli appunti"

#: applet/babeleo.cpp
msgid "More search engines"
msgstr "Altri motori di ricerca"

#: applet/babeleo.cpp
msgid "Manual query..."
msgstr "Ricerca manuale..."

#: applet/babeleo.cpp
msgid "A search engine with this name already exists."
msgstr "Esiste già un motore di ricerca con questo nome."

#: applet/package/contents/ui/main.qml
msgid "Babeleo Translator"
msgstr "Babeleo (traduttore)"

#: applet/package/contents/ui/main.qml
msgid "Current engine: %1"
msgstr "Motore corrente: %1"

#: applet/package/contents/ui/main.qml
msgid "Translate clipboard content\nCurrent engine: %1"
msgstr "Traduci contenuto degli appunti\nMotore corrente: %1"

#: applet/package/contents/ui/main.qml
msgid "Enter search term…"
msgstr "Inserisci termine di ricerca…"

#: applet/package/contents/ui/main.qml
msgid "Cancel"
msgstr "Annulla"

#: applet/package/contents/ui/main.qml
msgid "Search"
msgstr "Cerca"

#: applet/package/contents/config/config.qml
msgid "Search Engines"
msgstr "Motori di ricerca"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Fetch Icon"
msgstr "Scarica icona"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Download favicon from the website, if available"
msgstr "Scarica il favicon dal sito web, se disponibile"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Downloading…"
msgstr "Download in corso…"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Add"
msgstr "Aggiungi"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "New Engine"
msgstr "Nuovo motore"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Delete"
msgstr "Elimina"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Name:"
msgstr "Nome:"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "URL (%s = search term):"
msgstr "URL (%s = termine di ricerca):"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Icon:"
msgstr "Icona:"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Theme name or file path"
msgstr "Nome del tema o percorso file"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Visibility:"
msgstr "Visibilità:"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Hide this search engine"
msgstr "Nascondi questo motore di ricerca"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Position:"
msgstr "Posizione:"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Main menu"
msgstr "Menu principale"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "More search engines submenu"
msgstr "Sottomenu «Altri motori di ricerca»"

#: applet/babeleo.cpp
msgid "Open Babeleo manual query"
msgstr "Apri ricerca manuale Babeleo"

#: applet/package/contents/config/config.qml
msgid "Settings"
msgstr "Impostazioni"

#: applet/package/contents/ui/configShortcuts.qml
msgid "Click Behavior"
msgstr "Comportamento del clic"

#: applet/package/contents/ui/configShortcuts.qml
msgid "Single click: search with clipboard content"
msgstr "Clic singolo: cerca con il contenuto degli appunti"

#: applet/package/contents/ui/configShortcuts.qml
msgid "Double click: search with clipboard content"
msgstr "Doppio clic: cerca con il contenuto degli appunti"

#: applet/package/contents/ui/configShortcuts.qml
msgid "A single left click will open the context menu (same as right click)."
msgstr "Un singolo clic sinistro aprirà il menu contestuale (come il clic destro)."

#: applet/package/contents/ui/configShortcuts.qml
msgid "Keyboard Shortcut"
msgstr "Scorciatoia tastiera"

#: applet/package/contents/ui/configShortcuts.qml
msgid "Manual Query Shortcut"
msgstr "Scorciatoia ricerca manuale"

#: applet/package/contents/ui/configShortcuts.qml
msgid "Open manual query dialog:"
msgstr "Apri finestra di ricerca manuale:"

#: applet/package/contents/ui/main.qml
msgid "Ctrl+Click an engine to search without switching"
msgstr "Ctrl+Clic su un motore per cercare senza cambiare"

#: applet/package/contents/ui/main.qml
msgid "Ctrl+Click to search without switching engine"
msgstr "Ctrl+Clic per cercare senza cambiare motore"

#: applet/package/contents/ui/main.qml
msgid "One-shot — current engine unchanged"
msgstr "Una tantum — motore attuale invariato"

#: applet/package/contents/ui/main.qml
msgid "Ctrl+Shift+Click an engine to type a query for it"
msgstr "Ctrl+Maiusc+Clic su un motore per digitare una query"

#: applet/package/contents/ui/main.qml
msgid "Click to query clipboard content"
msgstr "Clic per interrogare il contenuto degli appunti"

#: applet/package/contents/ui/main.qml
msgid "Double-click to query clipboard content"
msgstr "Doppio clic per interrogare il contenuto degli appunti"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Export Search Engines"
msgstr "Esporta motori di ricerca"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Import Search Engines"
msgstr "Importa motori di ricerca"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "JSON files (*.json)"
msgstr "File JSON (*.json)"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "All files (*)"
msgstr "Tutti i file (*)"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Export…"
msgstr "Esporta…"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Import…"
msgstr "Importa…"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Export failed: %1"
msgstr "Esportazione non riuscita: %1"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Could not read the file."
msgstr "Impossibile leggere il file."

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Invalid JSON: %1"
msgstr "JSON non valido: %1"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "No engines found in the file."
msgstr "Nessun motore trovato nel file."

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Fetch All Icons"
msgstr "Scarica tutte le icone"

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Fetch missing favicons from their respective websites, if available."
msgstr "Scarica i favicon mancanti dai rispettivi siti web, se disponibili."

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Export the search engine list to a JSON file. Note: custom icons fetched from websites will not be included."
msgstr "Esporta l'elenco dei motori di ricerca in un file JSON. Nota: le icone personalizzate scaricate dai siti web non verranno incluse."

#: applet/package/contents/ui/configSearchEngines.qml
msgid "Import search engines from a JSON file. This will completely replace your current list."
msgstr "Importa motori di ricerca da un file JSON. Questo sostituirà completamente l'elenco attuale."
